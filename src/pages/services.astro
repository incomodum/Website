---
import "@/styles/globals.css"
import { SEO } from "astro-seo"
import Footer from "@/components/Footer"
import Header from "@/components/Header"
import ServicesList from "@/components/ServicesList"
import ThemeManager from "@/components/ThemeManager.astro"
import TechSection from "@/components/Technologies"
import Contact from "@/components/Contact"
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="icon" href="/favicon.png" type="image/png" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="manifest" href="/site.webmanifest" />
		<SEO
			title="Services | incomodum "
			description="Innovative Software Solutions Driving Growth and Excellence"
			openGraph={{
				basic: {
					title: "Services",
					type: "website",
					image: "/assets/base-og.png"
				},
				optional: {
					locale: "en",
					description:
						"Innovative Software Solutions Driving Growth and Excellence",
					siteName: "incomodum"
				},
				image: {
					width: 1280,
					height: 640,
					type: "image/png"
				}
			}}
			twitter={{
				card: "summary_large_image"
			}}
		/>
		<ThemeManager defaultTheme="auto" />
	</head>
	<body>
		<Header client:load />
		<div class="flex flex-col items-center w-full">
			<main class="w-full min-h-screen">
				<section class="relative pt-32 lg:pt-40 w-full px-8 lg:px-16">
					<div class="mx-auto max-w-7xl">
						<div class="mx-auto max-w-2xl md:text-center">
							<h1
								class="mb-6 text-4xl font-bold leading-tight lg:text-5xl"
							>
								Comprehensive <span class="text-page"
									>Software Solutions</span
								> for Your Business
							</h1>
							<p class="text-lg text-foreground/60">
								From custom software development to data
								analytics, we provide end-to-end solutions to
								help your business thrive in the digital age.
							</p>
						</div>
					</div>
				</section>

				<ServicesList client:visible />

				<TechSection client:visible />

				<section class="overflow-hidden lg:px-16 lg:py-24 scroll-mt-24 pb-24">
					<div class="mx-auto max-w-7xl">
						<Contact client:visible />
					</div>
				</section>
			</main>
		</div>
		<Footer client:load />
	</body>
</html>
