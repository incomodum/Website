---
import "@/styles/globals.css"
import { SEO } from "astro-seo"
import { ExternalLink, FileText, Layout, Database, Clock, Trophy, ShieldCheck, Globe } from "lucide-react"
import Footer from "@/components/Footer"
import Header from "@/components/Header"
import navody from "/public/assets/projects/navody.webp"
import ProjectsBack from "@/components/ProjectsBack.astro"
import ThemeManager from "@/components/ThemeManager.astro"
import { Badge } from "@/components/ui/badge"
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="icon" href="/favicon.png" type="image/png" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="manifest" href="/site.webmanifest" />
		<SEO
			title="navody.slovensko.sk | incomodum"
			description="Empowering Slovak Citizens with Tailored and Tutorials"
			openGraph={{
				basic: {
					title: "navody.slovensko.sk",
					type: "website",
					image: "/assets/projects/navody-og.png"
				},
				optional: {
					locale: "en",
					description:
						"Empowering Slovak Citizens with Tailored and Tutorials",
					siteName: "incomodum"
				},
				image: {
					width: 1280,
					height: 640,
					type: "image/png"
				}
			}}
			twitter={{
				card: "summary_large_image"
			}}
		/>
		<style>
			:root {
				/* Your specific Slovak Gov Blue */
				--page-color: oklch(0.4351 0.1553 263.78);
				--page-rgb: 0, 102, 204;
			}
		</style>
		<ThemeManager defaultTheme="auto" />
	</head>
	<body class="bg-background text-foreground selection:bg-page/30">
		<Header client:load />

		<main class="relative w-full">
			<section class="relative px-8 pt-24 pb-16 md:px-16 lg:pt-32 lg:pb-32 overflow-hidden">
				<div class="mx-auto max-w-7xl">
					<ProjectsBack />

					<div class="mt-12 grid gap-16 lg:grid-cols-2 items-center">
						<div class="space-y-8">
							<div class="space-y-4">
								<Badge className="bg-page/50 text-foreground hover:bg-page px-4 py-1 rounded-full uppercase tracking-widest text-[10px] font-bold">
									Government Digital Solution
								</Badge>
								<a href="https://navody.slovensko.sk" target="_blank" class="group block">
									<h1 class="text-5xl flex items-center font-black leading-[1.1] lg:text-6xl tracking-tighter transition-colors group-hover:text-page">
										<span class="text-page">navody</span>.slovensko.sk
										<ExternalLink className="inline-block ml-4 size-8 opacity-20 group-hover:opacity-100 transition-opacity" />
									</h1>
								</a>
								<p class="text-xl text-muted-foreground leading-relaxed max-w-xl">
									Empowering Slovak citizens by simplifying complex legal procedures through tailored, accessible digital guides.
								</p>
							</div>

							<div class="flex gap-8">
								<div class="flex flex-col border-l-2 border-page/20 pl-4">
									<span class="text-xs font-bold uppercase text-muted-foreground/50">Timeline</span>
									<span class="font-bold">6 Months Delivery</span>
								</div>
								<div class="flex flex-col border-l-2 border-page/20 pl-4">
									<span class="text-xs font-bold uppercase text-muted-foreground/50">Standards</span>
									<span class="font-bold">IDSK 3 / MIRRI</span>
								</div>
							</div>
						</div>

						<div class="relative group">
							<div class="absolute -inset-4 bg-page/5 blur-3xl rounded-full opacity-50"></div>
							<div class="relative overflow-hidden rounded-2xl shadow-2xl transition-all transform-gpu group-hover:scale-[1.02] border border-white/10">
								<img
									src={navody.src}
									alt="navody.slovensko.sk preview"
									class="w-full h-auto object-cover"
								/>
							</div>
							<div class="absolute -bottom-6 -right-6 h-32 w-32 bg-page/10 rounded-full blur-2xl -z-10"></div>
						</div>
					</div>
				</div>
			</section>

			<section class="bg-card/30 py-24 lg:py-32 backdrop-blur-sm border-y border-white/5">
				<div class="mx-auto max-w-7xl px-8 md:px-16">
					<div class="grid gap-24 lg:grid-cols-2">
						<div class="space-y-8">
							<div class="flex items-center gap-3 text-page">
								<ShieldCheck className="size-6" />
								<h2 class="text-3xl font-bold tracking-tight">The Challenge</h2>
							</div>
							<p class="text-lg text-muted-foreground leading-relaxed">
								Legal bureaucracy in Slovakia was often fragmented and difficult to navigate. The goal was to build a centralized hub for life-event guides that adhere to strict government accessibility standards (IDSK 3).
							</p>
							<ul class="space-y-5">
								{[
									"Dynamic content tailoring based on user profile",
									"Complex PDF generation for offline guide access",
									"Strict adherence to MIRRI design system guidelines"
								].map((item) => (
									<li class="flex items-start gap-4 group">
										<div class="mt-1 h-2 w-2 rounded-full bg-page group-hover:scale-150 transition-all" />
										<span class="text-muted-foreground group-hover:text-foreground transition-colors">{item}</span>
									</li>
								))}
							</ul>
						</div>

						<div class="space-y-8">
							<div class="flex items-center gap-3 text-page">
								<Trophy className="size-6" />
								<h2 class="text-3xl font-bold tracking-tight">The Heritage</h2>
							</div>
							<p class="text-lg text-muted-foreground leading-relaxed">
								Originally conceived as <b>InState</b> during the <i>hacknime.to</i> hackathon, we transformed a winning prototype into a production-ready system for the Slovak government.
							</p>

							<div class="grid gap-4 sm:grid-cols-2">
								<div class="rounded-2xl bg-card p-6 border border-white/5">
									<FileText className="text-page mb-4 size-6" />
									<h3 class="font-bold mb-2 text-sm uppercase">Custom CMS</h3>
									<p class="text-xs text-muted-foreground">Powering dynamic tutorials with October CMS flexibility.</p>
								</div>
								<div class="rounded-2xl bg-card p-6 border border-white/5">
									<Globe className="text-page mb-4 size-6" />
									<h3 class="font-bold mb-2 text-sm uppercase">IDSK 3 UI</h3>
									<p class="text-xs text-muted-foreground">Perfectly compliant with national design standards.</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="py-24 lg:py-32">
				<div class="mx-auto max-w-7xl px-8 md:px-16 text-center">
					<h2 class="mb-16 text-3xl font-bold lg:text-4xl">Technical <span class="text-page">Foundation</span></h2>
					<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
						{[
							{ title: "Framework", tech: "Next.js / React", icon: <Layout /> },
							{ title: "CMS", tech: "October CMS", icon: <Database /> },
							{ title: "Database", tech: "MySQL", icon: <Database /> },
							{ title: "Architecture", tech: "API-First Design", icon: <Clock /> }
						].map((item) => (
							<div class="group rounded-2xl bg-card/50 p-8 border border-white/5 hover:bg-card transition-all transform-gpu hover:-translate-y-2">
								<div class="mx-auto mb-6 w-fit text-page group-hover:rotate-12 transition-transform">
									{item.icon}
								</div>
								<h3 class="font-bold text-xs uppercase tracking-widest text-muted-foreground mb-2">{item.title}</h3>
								<p class="font-bold">{item.tech}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<section class="px-8 pb-32 md:px-16">
				<div class="mx-auto max-w-4xl rounded-[3rem] bg-linear-to-br from-[#003366] to-[#1C274C] p-12 text-center text-white shadow-2xl relative overflow-hidden">
					<div class="relative z-10">
						<h2 class="mb-6 text-3xl font-bold lg:text-4xl">Experience the project live</h2>
						<p class="mb-10 text-white/70 max-w-xl mx-auto">
							The platform is fully operational and helping thousands of citizens navigate their digital government services daily.
						</p>
						<a href="https://navody.slovensko.sk" target="_blank" class="inline-flex items-center rounded-full bg-white px-10 py-4 font-bold text-[#003366] hover:bg-page hover:text-white transition-all transform-gpu hover:scale-105">
							Visit navody.slovensko.sk
							<ExternalLink className="ml-2 size-4" />
						</a>
					</div>
					<div class="absolute -right-20 -bottom-20 size-80 bg-white/10 blur-3xl rounded-full"></div>
				</div>
			</section>
		</main>

		<Footer client:load />
	</body>
</html>