---
import "@/styles/globals.css"
import { SEO } from "astro-seo"
import Footer from "@/components/Footer"
import Header from "@/components/Header"
import ProjectsList from "@/components/ProjectsList"
import ThemeManager from "@/components/ThemeManager.astro"
import Contact from "@/components/Contact"
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="icon" href="/favicon.png" type="image/png" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="manifest" href="/site.webmanifest" />
		<SEO
			title="Projects | incomodum"
			description="Explore our portfolio of successful projects and see how we've helped businesses transform their digital presence."
			openGraph={{
				basic: {
					title: "Projects",
					type: "website",
					image: "/assets/base-og.png"
				},
				optional: {
					locale: "en",
					description:
						"Explore our portfolio of successful projects and see how we've helped businesses transform their digital presence.",
					siteName: "incomodum"
				},
				image: {
					width: 1280,
					height: 640,
					type: "image/png"
				}
			}}
			twitter={{
				card: "summary_large_image"
			}}
		/>
		<ThemeManager defaultTheme="auto" />
	</head>
	<body>
		<Header client:load />
		<div class="flex flex-col items-center w-full">
			<main class="w-full min-h-screen px-8 lg:px-16">
				<section class="relative pt-32 lg:pt-40 w-full">
					<div class="mx-auto max-w-7xl">
						<div class="mx-auto max-w-2xl md:text-center">
							<h1
								class="mb-6 text-4xl font-bold leading-tight lg:text-5xl"
							>
								Our Latest <span class="text-page"
									>Projects</span
								>
							</h1>
							<p class="text-lg text-foreground/60">
								Explore our portfolio of successful projects and
								see how we've helped businesses transform their
								digital presence.
							</p>
						</div>
					</div>
				</section>
				<ProjectsList client:visible />
				<div id="contact" class="scroll-mt-24 max-w-7xl mx-auto pb-24">
					<Contact client:visible />
				</div>
			</main>
		</div>
		<Footer client:load />
	</body>
</html>
